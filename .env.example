# OpenAI — set in local .env only; never commit real keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=15
OPENAI_MAX_TOKENS=300

# Email API
EMAIL_API_BASE_URL=http://localhost:8001
EMAIL_API_KEY=
MOCK_EMAILS=true
# Set true if backend supports GET /emails?since=ISO8601
EMAIL_API_SUPPORTS_SINCE=false
# Fernet key (from cryptography.fernet.Fernet.generate_key()) when body/subject are encrypted
EMAIL_PAYLOAD_ENCRYPTED=false
EMAIL_DECRYPT_KEY=
EMAIL_ENCRYPTED_FIELDS=body,subject

# Tuning
MAX_EMAILS=50
MAX_BODY_CHARS=500
TODAY_FETCH_LIMIT=200
CACHE_TTL_SECONDS=60
MAX_QUERY_LENGTH=500
MAX_CONTEXT_TOKENS=6000
CONTEXT_RESERVE_TOKENS=1500
TRIM_CHUNK=3

# Timezone (IANA)
USER_TIMEZONE=Asia/Kolkata

# OpenClaw gateway (mail_assistant calls POST /v1/chat/completions)
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=openclaw
OPENCLAW_TIMEOUT=120
# Backend LLM via x-openclaw-model header (must match openclaw models auth)
OPENCLAW_MODEL_OVERRIDE=google/gemini-2.5-flash

# /v1 tool API (OpenClaw-ready)
TOOL_SERVICE_API_KEYS=
TOOL_REQUIRE_AUTH=false
APPROVAL_SIGNING_SECRET=

CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
